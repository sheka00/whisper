# Hugging Face Token for Pyannote Speaker Diarization
# Access requirements:
# 1. Accept conditions for: https://hf.co/pyannote/speaker-diarization-3.1
# 2. Accept conditions for: https://hf.co/pyannote/speaker-diarization-community-1
# 3. Create a token with read access at: https://hf.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Whisper Model (large-v3-turbo, large-v3, medium, small, base, tiny)
WHISPER_MODEL=your_whisper_model_here

# Whisper batch size for parallel segment transcription (e.g. 16, 8, 4, 1)
WHISPER_BATCH_SIZE=your_batch_size_here

# Access credentials for the transcription service
ACCESS_USERNAME=your_username_here
ACCESS_PASSWORD=your_password_here

# Additional comma-separated accounts (username:password)
ADDITIONAL_ACCOUNTS=your_additional_username:your_additional_password,another_username:another_password
